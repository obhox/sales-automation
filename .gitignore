# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/mcp/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real secrets, but allow the example template
.env
.env.local
.env.development
.env.production
credentials.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database — contains personal data (LinkedIn cookies, lead lists)
*.db
*.db-shm
*.db-wal

# Runtime log file
log.txt

# Temporary / personal dev scripts — not useful to others
scripts/tmp/

# Playwright browser cache (downloaded automatically on first run)
/playwright-browsers

# Docker volume mount — contains the SQLite DB when running via docker-compose
/data

# open-core: premium pages are mirrored from ee/pages/ into pages/ by
# scripts/mirror-ee.js at predev/prebuild. The script writes a generated pages/.gitignore
# (read natively by git) that ignores the mirrored copies + manifest, so they are never
# tracked. Source of truth is ee/pages/**. NOTE: ee/ itself IS tracked in the private repo
# and is stripped only at publish time (.publish/), never via gitignore. See docs/OPEN_CORE.md.

# credentials
# One-off handoff doc (Opsily GHCR access instructions) — keep local, not tracked
docs/OPSILY_GHCR_ACCESS.md

# Internal audit deliverables — kept local for review, not published to the repo
CODEBASE_AUDIT.md
FIXES_APPLIED.md
