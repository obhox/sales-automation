# Copy this file to .env.local and fill in your values.
#
# SECURITY: .env.local holds real secrets. It is gitignored AND .dockerignored,
# so it is never committed and never baked into the Docker image. Keep it that way
# - inject secrets at runtime (env_file / orchestrator secrets), never at build time.
#
# The app validates required variables at startup (lib/env.ts). In production a
# missing REQUIRED variable stops the process with a clear error.

# --- REQUIRED (production) ---------------------------------------------------

# NextAuth - signs sessions AND derives the encryption key (lib/crypto.ts) for
# stored email passwords, LinkedIn cookies, API keys, and webhook secrets.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the app, used by NextAuth for redirects. Strongly recommended;
# also the default base for email open/click tracking links.
NEXTAUTH_URL=http://localhost:3000

# --- RECOMMENDED -------------------------------------------------------------

# Internal secret for server-to-server API calls (e.g. the MCP server calling
# Linki's own /api/* routes over loopback). Never sent to a browser or exposed
# externally - only Node processes on this host see it.
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=

# Instance administrators, comma-separated emails. These accounts can open /admin and
# read platform-wide, cross-workspace metrics (read-only, aggregates only).
# Deliberately an env var, not a database role: instance access therefore requires
# deploy access and can never be self-granted through the app. Leave blank to disable
# the admin surface entirely - an empty value means nobody is an administrator.
# SUPERADMIN_EMAILS=you@example.com,ops@example.com
SUPERADMIN_EMAILS=

# --- OPTIONAL ----------------------------------------------------------------

# Public HTTPS origin used by enhanced email open/click tracking. In production this
# must be reachable by recipients. Defaults to NEXTAUTH_URL when omitted.
EMAIL_TRACKING_BASE_URL=
# Optional dedicated HMAC secret for signed tracking URLs. Defaults to NEXTAUTH_SECRET.
EMAIL_TRACKING_SECRET=

# Additional HTTPS browser origins allowed to call the hosted MCP endpoint, comma-separated.
# Claude's official https://claude.ai and https://claude.com origins are allowed automatically.
MCP_ALLOWED_ORIGINS=

# SQLite database path. Defaults to ./linki.db in cwd.
# When running via Docker, this is set automatically to /data/linki.db
LINKI_DB_PATH=

# Set to "false" to show the browser window during automation (useful for debugging).
HEADLESS=true
